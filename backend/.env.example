PORT=3000

# --- Local Docker (see docker-compose.yml) — set DB_HOST=127.0.0.1 and DB_SSL=false ---
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=root
# DB_NAME=recettes
# DB_SSL=false

# --- Demo Aiven MySQL (defaults are also hardcoded in src/app.module.ts) ---
# DB_HOST=mysql-2b338b70-esi-cd05.a.aivencloud.com
# DB_PORT=14095
# DB_USER=avnadmin
# DB_NAME=defaultdb
# DB_SSL=true
# Optional: path to Aiven’s downloaded ca.pem (strict TLS). If unset, TLS still runs but cert chain is not verified (demo-friendly).
# DB_SSL_CA_PATH=
# Set to true only with DB_SSL_CA_PATH; otherwise leave unset for Aiven demos.
# DB_SSL_REJECT_UNAUTHORIZED=
# Required: paste the password from the Aiven console (never commit it).
DB_PASSWORD=

DB_LOGGING=false
JWT_SECRET=change-me-in-production
